generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Profile {
  id        String   @id
  username  String?  @unique
  email     String   @unique
  createdAt DateTime @default(now())

  players GamePlayer[]
}

model Game {
  id       String   @id @default(uuid())
  roomCode String   @unique
  mode     GameMode

  boardSize  Int @default(3)
  tieBreaker Int @default(3)

  status      GameStatus   @default(waiting)
  currentTurn PlayerSymbol

  createdAt DateTime @default(now())

  players GamePlayer[]
  moves   Move[]

  // winner PlayerSymbol?
}

model GamePlayer {
  id       String       @id @default(uuid())
  gameId   String
  userId   String?
  symbol   PlayerSymbol
  score    Int          @default(0)
  joinedAt DateTime     @default(now())

  game Game     @relation(fields: [gameId], references: [id])
  user Profile? @relation(fields: [userId], references: [id])

  @@unique([gameId, userId])
}

model Move {
  id        String        @id @default(uuid())
  gameId    String
  userId    String?
  symbol    PlayerSymbol?
  cell      Int
  moveNo    Int
  createdAt DateTime      @default(now())

  game Game @relation(fields: [gameId], references: [id])
}

enum GameMode {
  MULTI //MULTIPLYAER
  AI //VS COMPUTER
  DEVICE //OFFLINE
}

enum GameStatus {
  waiting
  active
  finished
}

enum PlayerSymbol {
  X
  O
}
